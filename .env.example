# Application
APP_NAME=AI Knowledge Assistant
APP_ENV=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Paths (relative to project root)
UPLOAD_DIR=uploads
VECTOR_DB_DIR=vector_db

# Upload limits
MAX_UPLOAD_SIZE_MB=100

# LLM provider (used in later phases)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# RAG settings (used in later phases)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# RETRIEVAL_TOP_K=5
# EMBEDDING_MODEL=all-MiniLM-L6-v2
